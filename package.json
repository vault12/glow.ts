{
  "name": "glow.ts",
  "version": "1.1.4",
  "displayName": "Glow.ts",
  "description": "Client library for interacting with Zax Cryptographic Relay Servers",
  "keywords": [
    "vault12",
    "glow",
    "typescript",
    "ts",
    "zax",
    "cryptographic",
    "relay"
  ],
  "author": "Vault12 <glow@vault12.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vault12/glow.ts.git"
  },
  "bugs": {
    "url": "https://github.com/vault12/glow.ts/issues"
  },
  "homepage": "https://github.com/vault12/glow.ts#readme",
  "license": "MIT",
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "prepublishOnly": "npm run build",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "test": "jest",
    "test:jsdom": "jest --selectProjects jsdom",
    "test:node": "jest --selectProjects node",
    "test:coverage": "jest --selectProjects node --coverage",
    "test:watch": "jest --selectProjects node --watch"
  },
  "type": "module",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/glow.es.js",
      "require": "./dist/glow.cjs.js"
    }
  },
  "dependencies": {
    "async-mutex": "0.5.0",
    "tweetnacl": "1.0.3"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@jest/types": "30.4.1",
    "@microsoft/api-extractor": "^7.57.7",
    "@types/jest": "30.0.0",
    "@types/node": "24.5.2",
    "eslint": "10.6.0",
    "jest": "30.4.2",
    "jest-environment-jsdom": "30.4.1",
    "jest-localstorage-mock": "2.4.26",
    "ts-jest": "29.4.11",
    "ts-node": "10.9.2",
    "typescript": "5.8.2",
    "typescript-eslint": "8.62.0",
    "unplugin-dts": "1.0.3",
    "vite": "8.1.0"
  }
}
